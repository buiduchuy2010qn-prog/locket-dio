{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "echo skip-install",
  "buildCommand": "echo prebuilt-static-ok",
  "outputDirectory": "vercel-static",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/dio-api",
      "destination": "https://huy-locket-api-production.up.railway.app/"
    },
    {
      "source": "/dio-api/:path*",
      "destination": "https://huy-locket-api-production.up.railway.app/:path*"
    },
    {
      "source": "/dio-auth",
      "destination": "https://huy-locket-api-production.up.railway.app/"
    },
    {
      "source": "/dio-auth/:path*",
      "destination": "https://huy-locket-api-production.up.railway.app/:path*"
    },
    {
      "source": "/dio-data",
      "destination": "https://data.locket-dio.com/"
    },
    {
      "source": "/dio-data/:path*",
      "destination": "https://data.locket-dio.com/:path*"
    },
    {
      "source": "/dio-storage",
      "destination": "https://storage.locket-dio.com/"
    },
    {
      "source": "/dio-storage/:path*",
      "destination": "https://storage.locket-dio.com/:path*"
    },
    {
      "source": "/dio-media",
      "destination": "https://media.locket-dio.com/"
    },
    {
      "source": "/dio-media/:path*",
      "destination": "https://media.locket-dio.com/:path*"
    },
    {
      "source": "/dio-export",
      "destination": "https://export.locket-dio.com/"
    },
    {
      "source": "/dio-export/:path*",
      "destination": "https://export.locket-dio.com/:path*"
    },
    {
      "source": "/dio-cdn",
      "destination": "https://cdn.locket-dio.com/"
    },
    {
      "source": "/dio-cdn/:path*",
      "destination": "https://cdn.locket-dio.com/:path*"
    },
    {
      "source": "/dio-payment",
      "destination": "https://payment.locket-dio.com/"
    },
    {
      "source": "/dio-payment/:path*",
      "destination": "https://payment.locket-dio.com/:path*"
    },
    {
      "source": "/api/drive-status",
      "destination": "https://huy-locket-production.up.railway.app/api/drive-status"
    },
    {
      "source": "/api/drive-config",
      "destination": "https://huy-locket-production.up.railway.app/api/drive-config"
    },
    {
      "source": "/api/drive-oauth-start",
      "destination": "https://huy-locket-production.up.railway.app/api/drive-oauth-start"
    },
    {
      "source": "/api/drive-oauth-callback",
      "destination": "https://huy-locket-production.up.railway.app/api/drive-oauth-callback"
    },
    {
      "source": "/api/drive-backup",
      "destination": "https://huy-locket-production.up.railway.app/api/drive-backup"
    },
    {
      "source": "/api/media-download",
      "destination": "https://huy-locket-production.up.railway.app/api/media-download"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/offline.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/workbox-(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
