{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --omit=dev --ignore-scripts || npm install --ignore-scripts",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/dio-api/:path*",
      "destination": "https://huy-locket-api-production.up.railway.app/:path*"
    },
    {
      "source": "/dio-auth/:path*",
      "destination": "https://auth.locket-dio.com/:path*"
    },
    {
      "source": "/dio-data/:path*",
      "destination": "https://data.locket-dio.com/:path*"
    },
    {
      "source": "/dio-storage/:path*",
      "destination": "https://storage.locket-dio.com/:path*"
    },
    {
      "source": "/dio-media/:path*",
      "destination": "https://media.locket-dio.com/:path*"
    },
    {
      "source": "/dio-export/:path*",
      "destination": "https://export.locket-dio.com/:path*"
    },
    {
      "source": "/dio-cdn/:path*",
      "destination": "https://cdn.locket-dio.com/:path*"
    },
    {
      "source": "/dio-payment/:path*",
      "destination": "https://payment.locket-dio.com/:path*"
    },
    {
      "source": "/((?!dio-|api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
