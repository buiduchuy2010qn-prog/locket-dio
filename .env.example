# ── Locket Dio production env ──
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://locket:locket@localhost:5432/locket_dio?schema=public

# Auth (use long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES=7d
COOKIE_SECURE=false

# Limits
FREE_FRIEND_LIMIT=5
FREE_VIDEO_MAX_SEC=5
GOLD_VIDEO_MAX_SEC=30
FREE_MAX_UPLOAD_MB=8
GOLD_MAX_UPLOAD_MB=50

# Cloudinary (optional — local disk fallback if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=locket-dio

# Stripe (optional — mock activate if empty)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Official Locket OAuth / partner API ONLY (never password, never private endpoints)
LOCKET_OAUTH_ENABLED=false
LOCKET_CLIENT_ID=
LOCKET_CLIENT_SECRET=
LOCKET_AUTH_URL=
LOCKET_TOKEN_URL=
# Documented upload URL when partner docs provide one
LOCKET_UPLOAD_URL=

# SMTP (optional — tokens logged in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Locket Dio <noreply@locket-dio.local>

# Frontend Vite
VITE_API_URL=http://localhost:4000
