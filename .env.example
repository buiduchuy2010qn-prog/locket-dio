# ── Locket Dio production environment ──
# Copy to .env and edit values. Never commit real secrets.

NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# PostgreSQL
DATABASE_URL=postgresql://locket:locket@localhost:5432/locket_dio?schema=public

# Auth — use a long random string in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES=7d
# true behind HTTPS in production
COOKIE_SECURE=false

# Feature limits (all accounts free / full access by default)
FREE_FRIEND_LIMIT=99999
FREE_VIDEO_MAX_SEC=60
GOLD_VIDEO_MAX_SEC=60
FREE_MAX_UPLOAD_MB=50
GOLD_MAX_UPLOAD_MB=50

# Cloudinary (optional — uses local disk under /uploads if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=locket-dio

# Stripe (optional — not required; features are free)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Official Locket partner OAuth ONLY (disabled by default — not used)
# Do NOT store Locket passwords. App is independent.
LOCKET_OAUTH_ENABLED=false
LOCKET_CLIENT_ID=
LOCKET_CLIENT_SECRET=
LOCKET_AUTH_URL=
LOCKET_TOKEN_URL=
LOCKET_UPLOAD_URL=

# SMTP (optional — verification tokens logged to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Locket Dio <noreply@locket-dio.local>

# Frontend (Vite) — leave empty in dev to use Vite proxy to :4000
# Production: public API origin e.g. https://api.yourdomain.com
VITE_API_URL=http://localhost:4000
# Force browser localStorage mock (no API)
VITE_FORCE_MOCK=false
