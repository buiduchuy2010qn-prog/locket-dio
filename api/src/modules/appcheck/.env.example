# =========================================
# AppCheck Redis
# Redis dùng để cache token + lock webhook
# =========================================
APPCHECK_REDIS_URL=redis://127.0.0.1:6379

# =========================================
# Internal collaboration secret key
# Dùng để xác thực giữa các service nội bộ
# =========================================
APPCHECK_COLLAB_KEY=your-secret-key

# =========================================
# Discord webhook URL
# URL webhook Discord để gửi log
# =========================================
APPCHECK_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# =========================================
# Discord thread IDs
# SUCCESS: log thành công
# ERROR: log lỗi AppCheck
# =========================================
APPCHECK_WEBHOOK_SUCCESS=1504922067961647225
APPCHECK_WEBHOOK_ERROR=1504922067961647999

# =========================================
# Optional proxy
# Có thể để trống nếu không dùng
# =========================================
APPCHECK_PROXY_URL=

# =========================================
# Device config
# App ID dùng để exchange AppCheck
# =========================================
# Firebase App ID
APPCHECK_DEVICE_ID=1:1234567890:ios:abcdef123456