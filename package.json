{
  "name": "huy-locket",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "license": "MIT",
  "description": "Huy Locket — web client for Locket, with Drive backup",
  "scripts": {
    "start": "node server.mjs",
    "dev": "vite",
    "build": "node scripts/vercel-prebuilt.mjs",
    "sync:ai-models": "node scripts/sync-ai-models.mjs",
    "verify:ai-models": "node scripts/verify-ai-models.mjs",
    "build:vite": "node scripts/write-version.mjs && node scripts/sync-ai-models.mjs && vite build && node scripts/verify-ai-models.mjs dist",
    "build:vercel-static": "npm run build:vite && node -e \"const fs=require('fs');const{cpSync,rmSync,existsSync}=fs;const d='vercel-static';if(existsSync(d))rmSync(d,{recursive:true});cpSync('dist',d,{recursive:true});console.log('synced dist -> vercel-static')\" && node scripts/verify-ai-models.mjs dist vercel-static",
    "build:static": "node scripts/write-version.mjs && node scripts/sync-ai-models.mjs && node scripts/clean-public-build.mjs && vite build && node scripts/prepare-static.mjs && node scripts/verify-ai-models.mjs dist public",
    "lint": "eslint .",
    "preview": "vite preview",
    "serve": "node server.mjs"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "4.1.13",
    "@tanstack/react-virtual": "^3.14.4",
    "@tensorflow/tfjs": "^4.11.0",
    "@upscalerjs/esrgan-slim": "^1.0.0",
    "axios": "^1.8.1",
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "dexie": "^4.0.11",
    "driver.js": "^1.4.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jwt-decode": "^4.0.0",
    "ldrs": "^1.0.2",
    "lucide-react": "^0.563.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.4.2",
    "react-fast-marquee": "^1.6.5",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.2.0",
    "react-turnstile": "^1.1.4",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "swiper": "^12.0.3",
    "upscaler": "^1.0.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.20",
    "daisyui": "^5.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "postcss": "^8.5.3",
    "rollup-plugin-visualizer": "^6.0.1",
    "tailwindcss": "4.1.13",
    "vite": "^6.2.5",
    "vite-plugin-pwa": "^1.0.0"
  }
}
