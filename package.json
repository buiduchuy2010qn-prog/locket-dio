{
  "name": "locket-dio",
  "version": "1.0.0",
  "private": true,
  "description": "Locket Dio — private close-friends photo & video sharing (full-stack)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev -w @locket-dio/api\" \"npm run dev -w @locket-dio/web\"",
    "dev:api": "npm run dev -w @locket-dio/api",
    "dev:web": "npm run dev -w @locket-dio/web",
    "build": "npm run build -w @locket-dio/shared && npm run build -w @locket-dio/api && npm run build -w @locket-dio/web",
    "build:web": "npm run build -w @locket-dio/web",
    "build:api": "npm run build -w @locket-dio/api",
    "start:api": "npm run start -w @locket-dio/api",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^6.5.0"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20"
  }
}
